; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="EternalLibrary"
run/main_scene="uid://busuj7ik35y8"
config/features=PackedStringArray("26.1", "GL Compatibility", "Redot")
config/icon="res://icon.svg"

[autoload]

GameEnv="*res://Scripts/game_env.gd"
Signals="*res://Scripts/Utils/signals.gd"
ConfigurationManager="*res://Scripts/Managers/configuration_manager.gd"
GalleryConfigManager="*res://Scripts/Managers/gallery_config_manager.gd"
EntityConfigManager="*res://Scripts/Managers/entity_config_manager.gd"
SpawnTableManager="*res://Scripts/Managers/spawn_table_manager.gd"

[debug]

file_logging/enable_file_logging=true
file_logging/log_path="res://Builds/Logs/debugs.log"

[filesystem]

import/blender/enabled=false

